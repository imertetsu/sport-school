# .env.example — variables de entorno de CanteraSport.
# Copia este archivo a `.env` (NO se commitea) y ajusta los valores.
# Aquí SOLO van placeholders de desarrollo, jamás secretos reales.

# --- Branding / config (C0) ---
APP_NAME=CanteraSport

# --- Base de datos (C7) ---
# La APP corre como cantera_app (NOSUPERUSER, NOBYPASSRLS): RLS efectiva.
DATABASE_URL=postgresql+psycopg://cantera_app:devpass@db:5432/cantera
# Alembic corre como OWNER (rol postgres) — solo para migraciones.
MIGRATION_DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/cantera

# Password del superusuario de Postgres (lo consume el servicio `db`).
POSTGRES_PASSWORD=postgres

# --- Broker de Celery ---
REDIS_URL=redis://redis:6379/0

# --- Auth / JWT (C4) ---
JWT_SECRET=dev-change-me
JWT_EXPIRE_MINUTES=480

# --- CORS / Frontend (C7) ---
CORS_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:8000
