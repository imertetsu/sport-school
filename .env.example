# .env.example — variables de entorno de LatinoSport.
# Copia este archivo a `.env` (NO se commitea) y ajusta los valores.
# Aquí SOLO van placeholders de desarrollo, jamás secretos reales.

# --- Branding / config (C0) ---
APP_NAME=LATINOSPORT
# Entorno: dev | production. En production la app NO arranca con secretos de dev
# (JWT_SECRET débil, credenciales devpass, OPENBCB_SANDBOX=true) — ver guard en config.py.
APP_ENV=dev

# --- Base de datos (C7) ---
# La APP corre como latinosport_app (NOSUPERUSER, NOBYPASSRLS): RLS efectiva.
DATABASE_URL=postgresql+psycopg://latinosport_app:devpass@db:5432/latinosport
# Alembic corre como OWNER (rol postgres) — solo para migraciones.
MIGRATION_DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/latinosport

# Password del superusuario de Postgres (lo consume el servicio `db`).
POSTGRES_PASSWORD=postgres
# Password del rol de app `latinosport_app` (lo crea la migración 0001 en BD nueva).
# Debe COINCIDIR con el password dentro de DATABASE_URL (latinosport_app:<APP_DB_PASSWORD>).
APP_DB_PASSWORD=devpass

# --- Broker de Celery ---
REDIS_URL=redis://redis:6379/0

# --- Auth / JWT (C4) ---
JWT_SECRET=dev-change-me
JWT_EXPIRE_MINUTES=480

# --- CORS / Frontend (C7) ---
CORS_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:8000

# --- Cobranza: OpenBCB / WhatsApp (C8) ---
# Sandbox ON: habilita el endpoint .../qr/{id}/simular-confirmacion (sin BCB real).
# En prod va a false (requiere onboarding/credenciales BCB — SRS §10.3).
OPENBCB_SANDBOX=true
# URL base y API key del proveedor OpenBCB (vacías en dev; secretos por env/secret store).
OPENBCB_BASE_URL=
OPENBCB_API_KEY=
# Adaptador de notificación: noop (no envía nada; RNF-07, sin costo en CI/preview).
WHATSAPP_PROVIDER=noop

# WhatsApp Cloud API (saliente)
# WHATSAPP_PROVIDER ya existe arriba (noop); cambiar a "meta" cuando haya credenciales reales.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=        # secreto: real va por secret manager, nunca commitear
WHATSAPP_WABA_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=          # secreto
WHATSAPP_GRAPH_VERSION=v21.0
RECORDATORIO_QR_DIAS_ANTES=3

# --- Programación de clases (Fase 2) ---
# Ventana (días) que el cron genera de sesiones a partir de los horarios, y antelación
# (horas) del recordatorio de clase. Defaults seguros; opcional sobreescribir.
GENERAR_SESIONES_DIAS=7
RECORDATORIO_CLASE_HORAS=2

# ============================================================================
# PRODUCCIÓN — checklist (NO usar los valores de arriba en prod)
# ----------------------------------------------------------------------------
#   APP_ENV=production
#   JWT_SECRET=<aleatorio >=32 chars>          # p.ej. `openssl rand -hex 32`
#   APP_DB_PASSWORD=<pass_fuerte_app>         # password del rol latinosport_app (BD nueva)
#   DATABASE_URL=postgresql+psycopg://latinosport_app:<pass_fuerte_app>@db:5432/latinosport   # == APP_DB_PASSWORD
#   MIGRATION_DATABASE_URL=postgresql+psycopg://postgres:<pass_fuerte_pg>@db:5432/latinosport
#   POSTGRES_PASSWORD=<pass_fuerte_pg>        # superusuario de la instancia (== en MIGRATION_DATABASE_URL)
#   CORS_ORIGINS=https://<tu-dominio>          # solo orígenes reales
#   VITE_API_URL=https://api.<tu-dominio>      # se hornea en el build del frontend
#   OPENBCB_SANDBOX=false + OPENBCB_BASE_URL/OPENBCB_API_KEY reales (onboarding BCB)
#   WHATSAPP_PROVIDER=<bsp real> + sus credenciales
#   Gestiona estos secretos con un secret manager, nunca en el repo.
#   La app valida esto al arrancar (config.py `_guard_prod`): con APP_ENV=production
#   y un secreto/credencial de dev, FALLA en el arranque (fail-fast).
# ============================================================================
