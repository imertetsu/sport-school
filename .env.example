# .env.example — variables de entorno de LatinoSport.
# Copia este archivo a `.env` (NO se commitea) y ajusta los valores.
# Aquí SOLO van placeholders de desarrollo, jamás secretos reales.

# --- Branding / config (C0) ---
APP_NAME=LATINOSPORT
# Entorno: dev | production. En production la app NO arranca con secretos de dev
# (JWT_SECRET débil, credenciales devpass, OPENBCB_SANDBOX=true) — ver guard en config.py.
APP_ENV=dev

# --- Base de datos (C7) ---
# La APP corre como latinosport_app (NOSUPERUSER, NOBYPASSRLS): RLS efectiva.
DATABASE_URL=postgresql+psycopg://latinosport_app:devpass@db:5432/latinosport
# Alembic corre como OWNER (rol postgres) — solo para migraciones.
MIGRATION_DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/latinosport

# Password del superusuario de Postgres (lo consume el servicio `db`).
POSTGRES_PASSWORD=postgres
# Password del rol de app `latinosport_app` (lo crea la migración 0001 en BD nueva).
# Debe COINCIDIR con el password dentro de DATABASE_URL (latinosport_app:<APP_DB_PASSWORD>).
APP_DB_PASSWORD=devpass

# --- Broker de Celery ---
REDIS_URL=redis://redis:6379/0

# --- Auth / JWT (C4) ---
JWT_SECRET=dev-change-me
JWT_EXPIRE_MINUTES=480

# --- CORS / Frontend (C7) ---
CORS_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:8000

# --- Cobranza: OpenBCB / WhatsApp (C8) ---
# Sandbox ON: habilita el endpoint .../qr/{id}/simular-confirmacion (sin BCB real).
# En prod va a false (requiere onboarding/credenciales BCB — SRS §10.3).
OPENBCB_SANDBOX=true
# URL base y API key del proveedor OpenBCB (vacías en dev; secretos por env/secret store).
OPENBCB_BASE_URL=
OPENBCB_API_KEY=
# Adaptador de notificación: noop (no envía nada; RNF-07, sin costo en CI/preview).
# Valores: noop | mock | meta | gateway.
#   - meta    → WhatsApp Cloud API oficial (requiere credenciales Meta + plantillas aprobadas).
#   - gateway → sidecar Baileys NO-OFICIAL (número de prueba, pairing por QR); ver más abajo.
WHATSAPP_PROVIDER=noop

# WhatsApp Cloud API (saliente, provider=meta)
# WHATSAPP_PROVIDER ya existe arriba (noop); cambiar a "meta" cuando haya credenciales reales.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=        # secreto: real va por secret manager, nunca commitear
WHATSAPP_WABA_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=          # secreto
WHATSAPP_GRAPH_VERSION=v21.0
RECORDATORIO_QR_DIAS_ANTES=3

# --- WhatsApp Gateway NO-OFICIAL (provider=gateway, sidecar Baileys MULTI-SESION) ---
# El adaptador Python del backend (GatewayWhatsAppAdapter) consume la HTTP API del
# sidecar `whatsapp-gateway` (servicio del compose). Para enviar de verdad por este
# canal: WHATSAPP_PROVIDER=gateway + las dos vars de abajo. Sin ellas ⇒ degrada a mock.
#
# MULTI-TENANT: la API del sidecar es ahora POR-ORG (un número por escuela). Las rutas
# son /sessions/{org_id}/status · /sessions/{org_id}/qr · /sessions/{org_id}/send y
# DELETE /sessions/{org_id} (más /healthz sin token). La vieja ruta global /send YA NO
# existe. El backend siempre usa el org_id DEL TOKEN (nunca lo elige el cliente).
#
# URL interna del sidecar dentro de la red docker (nombre de servicio + GATEWAY_PORT).
WHATSAPP_GATEWAY_URL=http://whatsapp-gateway:3000
# Token compartido que autentica AMBAS direcciones (X-Gateway-Token). Secreto: real por
# secret manager, nunca commitear. DEBE ser el MISMO valor que GATEWAY_TOKEN de abajo.
WHATSAPP_GATEWAY_TOKEN=dev-gateway-token-change-me   # secreto

# Vars del sidecar `whatsapp-gateway` (las lee el contenedor Node):
# GATEWAY_TOKEN === WHATSAPP_GATEWAY_TOKEN (mismo valor, autentica ambas direcciones).
GATEWAY_TOKEN=dev-gateway-token-change-me             # secreto (== WHATSAPP_GATEWAY_TOKEN)
# Puerto HTTP del sidecar (interno y, opcionalmente, expuesto al host por el compose).
GATEWAY_PORT=3000
# Raíz del auth-state MULTI-SESION dentro del contenedor: el sidecar guarda un subdir por
# org en ${SESSIONS_ROOT}/${org_id} y monta esta ruta en el volumen `whatsapp_sessions`
# (ver docker-compose.yml). REEMPLAZA al antiguo SESSION_DIR (mono-número). Default
# /data/sessions; normalmente NO hace falta sobreescribirlo.
SESSIONS_ROOT=/data/sessions
# Webhook del backend al que el sidecar reenvía los mensajes ENTRANTES. `api` es el
# nombre del servicio interno del compose. Esta ruta es DISTINTA de /webhooks/whatsapp
# (que es el webhook de estados de Meta). MULTI-TENANT: el body ahora incluye `org_id`
# (la org de la sesión que recibió el mensaje): { org_id, from, text, message_id, timestamp }.
INBOUND_CALLBACK_URL=http://api:8000/api/v1/webhooks/whatsapp-inbound
# SOLO para BUILD del sidecar detrás del proxy TLS del equipo (gotcha del HANDOFF):
# a true desactiva la verificación de certificado en npm/apt DURANTE EL BUILD (no en
# runtime). Default false. En CI/prod déjalo en false (usar una CA/registry confiable).
GATEWAY_BUILD_INSECURE_TLS=false

# --- Programación de clases (Fase 2) ---
# Ventana (días) que el cron genera de sesiones a partir de los horarios, y antelación
# (horas) del recordatorio de clase. Defaults seguros; opcional sobreescribir.
GENERAR_SESIONES_DIAS=7
RECORDATORIO_CLASE_HORAS=2

# ============================================================================
# PRODUCCIÓN — checklist (NO usar los valores de arriba en prod)
# ----------------------------------------------------------------------------
#   APP_ENV=production
#   JWT_SECRET=<aleatorio >=32 chars>          # p.ej. `openssl rand -hex 32`
#   APP_DB_PASSWORD=<pass_fuerte_app>         # password del rol latinosport_app (BD nueva)
#   DATABASE_URL=postgresql+psycopg://latinosport_app:<pass_fuerte_app>@db:5432/latinosport   # == APP_DB_PASSWORD
#   MIGRATION_DATABASE_URL=postgresql+psycopg://postgres:<pass_fuerte_pg>@db:5432/latinosport
#   POSTGRES_PASSWORD=<pass_fuerte_pg>        # superusuario de la instancia (== en MIGRATION_DATABASE_URL)
#   CORS_ORIGINS=https://<tu-dominio>          # solo orígenes reales
#   VITE_API_URL=https://api.<tu-dominio>      # se hornea en el build del frontend
#   OPENBCB_SANDBOX=false + OPENBCB_BASE_URL/OPENBCB_API_KEY reales (onboarding BCB)
#   WHATSAPP_PROVIDER=<bsp real> + sus credenciales
#   Gestiona estos secretos con un secret manager, nunca en el repo.
#   La app valida esto al arrancar (config.py `_guard_prod`): con APP_ENV=production
#   y un secreto/credencial de dev, FALLA en el arranque (fail-fast).
# ============================================================================
