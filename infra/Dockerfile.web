# syntax=docker/dockerfile:1
#
# Imagen del frontend de LatinoSport (React + Vite).
# Build context = ../frontend (ver docker-compose.yml: services.web.build.context).
#
# Multi-stage: build con node:24 -> servir el `dist/` estatico con nginx:alpine.
# VITE_API_URL se inyecta en build (Vite hornea las VITE_* en tiempo de build).

# --- Stage 1: build -------------------------------------------------------
FROM node:24-slim AS build

WORKDIR /app

# Cache de dependencias: copiamos manifiestos primero.
COPY package.json package-lock.json* ./
# `npm ci` si hay lockfile; si no, `npm install` (handoff frontend-dev: commitear
# package-lock.json para builds reproducibles).
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

# Resto del codigo y build.
COPY . .

# VITE_API_URL llega como build-arg (Vite lo hornea en el bundle).
ARG VITE_API_URL=http://localhost:8000
ENV VITE_API_URL=${VITE_API_URL}
RUN npm run build

# --- Stage 2: runtime (nginx sirviendo dist/) -----------------------------
FROM nginx:alpine AS runtime

# nginx sirve la SPA Y hace de PROXY INVERSO a la API: el navegador habla con UN
# solo puerto/origen (este), y la API (contenedor `api`) NO se expone al cliente.
# Asi la SPA usa rutas relativas (/api/...) y desaparece el CORS y la IP horneada.
COPY --chmod=0644 <<'EOF' /etc/nginx/conf.d/default.conf
server {
    listen 5173;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # DNS interno de docker: resuelve el servicio `api` en tiempo de request
    # (sobrevive a reinicios/recreaciones del contenedor api -> evita IP cacheada).
    resolver 127.0.0.11 valid=30s ipv6=off;

    # API (incluye webhooks y comprobantes PDF, todos bajo /api/v1) -> api:8000.
    location /api/ {
        set $api_upstream api;
        proxy_pass http://$api_upstream:8000$request_uri;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Comodidades del backend por el mismo puerto (chequeos / explorador de API).
    location = /health       { set $api_upstream api; proxy_pass http://$api_upstream:8000$request_uri; }
    location = /openapi.json { set $api_upstream api; proxy_pass http://$api_upstream:8000$request_uri; }
    location /docs           { set $api_upstream api; proxy_pass http://$api_upstream:8000$request_uri; proxy_set_header Host $host; }
    location /redoc          { set $api_upstream api; proxy_pass http://$api_upstream:8000$request_uri; proxy_set_header Host $host; }

    # SPA: cualquier otra ruta -> index.html (React Router).
    location / {
        try_files $uri $uri/ /index.html;
    }
}
EOF

COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 5173
CMD ["nginx", "-g", "daemon off;"]
